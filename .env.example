# Homelab Environment Configuration
# Copy this file to .env and customize the values for your setup

# Timezone (e.g., Europe/Paris, America/New_York — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=

# Domain configuration
# Your domain name for services (e.g., home.example.com)
DOMAIN=

# Network configuration
# Your router's public IP address (for WireGuard endpoint)
PUBLIC_IP=

# Network interface for initramfs (run: `ip link`)
NETWORK_INTERFACE=

# EFI partition UUID (run: `sudo blkid /dev/nvme0n1p1` or similar)
EFI_FS_UUID=

# Boot partition UUID (run: `sudo blkid /dev/nvme0n1p2` or similar)
BOOT_FS_UUID=

# Root partition LUKS UUID (run: `sudo blkid /dev/nvme0n1p3` or similar)
ROOT_LUKS_UUID=

# Data partition LUKS UUID (run: `sudo blkid /dev/sda1` or similar)
DATA_LUKS_UUID=

# Data partition filesystem UUID (run: `sudo blkid /dev/mapper/data` after configuring LUKS on the external drive)
DATA_FS_UUID=

# Backup partition LUKS UUID (run: `sudo blkid /dev/sdb1` or similar)
BACKUP_LUKS_UUID=
